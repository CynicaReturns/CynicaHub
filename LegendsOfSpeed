--// CynicaHub - Speed Simulator \\--
if game.PlaceId == 3101667897 then
    repeat wait() until game:IsLoaded()
    if not syn then
        game.StarterGui:SetCore("SendNotification", {
            Title = "CynicaHub",
            Text = "You are not using Synapse X, this is a Synapse X Only Hub",
            Duration = 4
        })
        return
    else
        game.StarterGui:SetCore("SendNotification", {
            Title = "CynicaHub",
            Text = "You are using Synapse X",
            Duration = 4
        })
    end
    for _, v in pairs(game.Players.LocalPlayer:GetChildren()) do
        if v.Name == "CynicaHub^" or v.Name == "CynicaHub^^" then
            v:Destroy() 
        end
    end
    local args = {
        [1] = "disableTrading"
    }
    game:GetService("ReplicatedStorage").rEvents.tradingEvent:FireServer(unpack(args))
    --// Library \\--
    local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/xHeptc/Kavo-UI-Library/main/source.lua"))()
    local Window = Library.CreateLib("CynicaHub - Synapse Edition", "Ocean")
    --// Auto Farm \\--
    local AutoFarm = Window:NewTab("Auto Farm")
    local AutoFarmSection = AutoFarm:NewSection("Orbs/Gems")
    local HoopsSection = AutoFarm:NewSection("Hoops")
    local RebirthSection = AutoFarm:NewSection("Rebirth")
    local EggSection = AutoFarm:NewSection("Eggs")
    local areaSelected = Instance.new("StringValue")
    areaSelected.Parent = game.Players.LocalPlayer
    areaSelected.Name = "CynicaHub^"
    areaSelected.Value = "None"
    AutoFarmSection:NewDropdown("Select Area", "Choose the Area where you wanna Auto Collect", {"City", "Grass Race", "Magma Race"}, function(v)
        areaSelected.Value = v
    end)
    AutoFarmSection:NewToggle("Auto Collect", "Auto collects all Orbs/Gems", function(v)
        getgenv().autoOrbs = v
        local playerHead = game.Players.LocalPlayer.Character.Head
        while wait() do
            if not getgenv().autoOrbs then return end
            for i, v in pairs(game:GetService("Workspace").orbFolder[areaSelected.Value]:GetDescendants()) do
                if v.Name == "TouchInterest" and v.Parent then
                    firetouchinterest(playerHead, v.Parent, 0)
                end
            end
        end
    end)
    HoopsSection:NewToggle("Auto Hoops", "Auto collects all Hoops", function(v)
        getgenv().autoHoops = v
        local playerHead = game.Players.LocalPlayer.Character.Head
        while wait() do
            if not getgenv().autoHoops then return end
            for i, v in pairs(game:GetService("Workspace").Hoops:GetDescendants()) do
                if v.Name == "TouchInterest" and v.Parent then
                    firetouchinterest(playerHead, v.Parent, 0)
                end
            end
        end
    end)
    local eggSelected = Instance.new("StringValue")
    eggSelected.Parent = game.Players.LocalPlayer
    eggSelected.Name = "CynicaHub^^"
    eggSelected.Value = "None"
    EggSection:NewDropdown("Select Egg", "Choose Egg that you wanna Auto Open", {"Lightning Crystal", "Yellow Crystal"}, function(v)
        eggSelected.Value = v
    end)
    EggSection:NewToggle("Auto Open", "Auto opens the selected Egg", function(v)
        getgenv().autoEgg = v
        while wait() do
            if not getgenv().autoEgg then return end
            if eggSelected.Value == "Lightning Crystal" then
                local args = {
                    [1] = "openCrystal",
                    [2] = "Lightning Crystal"
                }
                game:GetService("ReplicatedStorage").rEvents.openCrystalRemote:InvokeServer(unpack(args))
            elseif eggSelected.Value == "Yellow Crystal" then
                local args = {
                    [1] = "openCrystal",
                    [2] = "Yellow Crystal"
                }
                game:GetService("ReplicatedStorage").rEvents.openCrystalRemote:InvokeServer(unpack(args))
            end
        end
    end)
    RebirthSection:NewToggle("Auto Rebirth", "Auto rebirths you", function(v)
        getgenv().autoRebirth = v
        while wait() do
            if not getgenv().autoRebirth then return end
            local args = {
                [1] = "rebirthRequest"
            }
            game:GetService("ReplicatedStorage").rEvents.rebirthEvent:FireServer(unpack(args))
        end
    end)
    --// Misc \\--
    local Misc = Window:NewTab("Misc")
    local MiscSection = Misc:NewSection("Misc")
    MiscSection:NewButton("Server Hop", "Joins a new Server", function()
        local x = {}
        for _, v in ipairs(game:GetService("HttpService"):JSONDecode(game:HttpGetAsync("https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Asc&limit=100")).data) do
            if type(v) == "table" and v.maxPlayers > v.playing and v.id ~= game.JobId then
                x[#x + 1] = v.id
            end
        end
        if #x > 0 then
            game:GetService("TeleportService"):TeleportToPlaceInstance(game.PlaceId, x[math.random(1, #x)])
        else
            return game.StarterGui:SetCore("SendNotification", {
                Title = "CynicaHub",
                Text = "Couldn't find a Server",
                Duration = 4
            })
        end
    end)
    MiscSection:NewButton("FPS Booster", "Reduces Lag", function()
        loadstring(game:HttpGet("https://pastebin.com/raw/NtgnwqYk"))()
    end)
    --// Fun \\--
    local Fun = Window:NewTab("Fun")
    local FunSection = Fun:NewSection("Fun")
    FunSection:NewButton("Remove Legs", "Removes the Legs from your Character", function()
        game.Players.LocalPlayer.Character.LeftLowerLeg:Destroy()
        game.Players.LocalPlayer.Character.LeftUpperLeg:Destroy()
        game.Players.LocalPlayer.Character.RightLowerLeg:Destroy()
        game.Players.LocalPlayer.Character.RightUpperLeg:Destroy()
    end)
    FunSection:NewButton("Remove Arms", "Removes the Arms from your Character", function()
        game.Players.LocalPlayer.Character.LeftLowerArm:Destroy()
        game.Players.LocalPlayer.Character.LeftUpperArm:Destroy()
        game.Players.LocalPlayer.Character.RightLowerArm:Destroy()
        game.Players.LocalPlayer.Character.RightUpperArm:Destroy()
    end)
    FunSection:NewButton("Remove Face", "Removes the Face from your Character", function()
        game.Players.LocalPlayer.Character.Head.face:Destroy()
    end)
    --// Credits \\--
    local Credits = Window:NewTab("Credits")
    local CreditsSection = Credits:NewSection("Credits")
    local Credits2Section = Credits:NewSection("cynicamane#7676 - Main Scripter")
    Credits2Section:NewKeybind("Toggle UI", "Choose a Keybind to Toggle UI", Enum.KeyCode.RightControl,function()
        Library:ToggleUI()
    end)
    game:GetService("Players").LocalPlayer.OnTeleport:Connect(function(State)
        if State == Enum.TeleportState.Started then
            local queueTeleport = syn and syn.queue_on_teleport or queue_on_teleport
            if queueTeleport then
                queueTeleport("loadstring(game:HttpGet('https://raw.githubusercontent.com/cynicamanee/CynicaHub/main/LegendsOfSpeed'))()")
            end
        end
    end)
end
